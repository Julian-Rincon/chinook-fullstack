# Database connection used by the FastAPI backend.
DB_HOST=your-rds-endpoint.amazonaws.com
DB_PORT=5432
DB_NAME=chinook
DB_USER=chinook_app
DB_PASSWORD=replace-me

# Authentication settings. Use a long random secret in production.
AUTH_SECRET_KEY=replace-with-a-long-random-secret
AUTH_ACCESS_TOKEN_MINUTES=480

# When set to 0, the backend can create its app_user table on startup.
# When set to 1, startup will skip that initialization step.
SKIP_DB_INIT=0

# Comma-separated frontend origins allowed by CORS.
# Example:
# CORS_ALLOW_ORIGINS=https://app.example.com,http://localhost:5173
CORS_ALLOW_ORIGINS=https://your-frontend-domain.example
